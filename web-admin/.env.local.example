# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase credentials
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub token for auto-syncing Localizable.xcstrings from the repo
# Generate at: https://github.com/settings/tokens (needs 'repo' scope for private repos)
GITHUB_TOKEN=
